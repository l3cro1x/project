cmake_minimum_required(VERSION 3.0.2)
project(delivery_sim)

find_package(catkin REQUIRED COMPONENTS
  geometry_msgs
  rospy
  std_msgs
  turtlesim
  message_generation
)

add_service_files(
  FILES
  Order.srv
)

generate_messages(
  DEPENDENCIES
  geometry_msgs
  std_msgs
)

catkin_package(
  CATKIN_DEPENDS geometry_msgs rospy std_msgs turtlesim message_runtime
)

include_directories(
  ${catkin_INCLUDE_DIRS}
)
